# --- General / OS ---
.DS_Store
.history
.svn/
*.log
*.bak
*.swp
*.class
migrate_working_dir/

# --- IDEs (VS Code & IntelliJ) ---
.vscode/
.idea/
*.iml
*.ipr
*.iws
.atom/

# --- Secret / Environment Management ---
# (Crucial for Veda.Herb security)
.env
.env.*
!.env.example
/veda_app/lib/env/env.g.dart

# --- Flutter & Dart (Global Search) ---
**/build/
**/.dart_tool/
**/.packages
**/.pub-cache/
**/.pub/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.metadata
**/doc/api/
/coverage/

# --- Android Specific ---
**/*.keystore
**/*.jks
**/android/local.properties
**/android/.gradle/
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
app.*.symbols
app.*.map.json

# --- Astro & Node.js (Global Search) ---
**/node_modules/
**/.astro/
**/dist/
**/npm-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*

# --- CRITICAL: GITHUB PAGES DEPLOYMENT ---
# We force Git to track these even if a rule above accidentally flags them
!/docs/
!/docs/**
!.nojekyll

# --- Ignore the LLM models ---
/models